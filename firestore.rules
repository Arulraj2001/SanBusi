rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read/write to all collections for testing/demo database connectivity
    match /services/{id} {
      allow read, write: if true;
    }
    match /portfolio/{id} {
      allow read, write: if true;
    }
    match /blog/{id} {
      allow read, write: if true;
    }
    match /testimonials/{id} {
      allow read, write: if true;
    }
    match /faqs/{id} {
      allow read, write: if true;
    }
    match /careers/{id} {
      allow read, write: if true;
    }
    match /contactMessages/{id} {
      allow read, write: if true;
    }
    match /settings/{id} {
      allow read, write: if true;
    }
    match /admins/{id} {
      allow read, write: if true;
    }

    // Feedback collection:
    // - Anyone can submit (create) feedback
    // - Anyone can read (public showcase, filtering done client-side by status)
    // - Admins can update status (approve/reject) and delete
    match /feedback/{id} {
      allow read, write: if true;
    }
  }
}
